{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shawnc7208.github.io/APD/schema/apd-v0.1.schema.json",
  "title": "Agent Procedure Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "spec_version",
    "procedure_id",
    "revision",
    "title",
    "summary",
    "entry_conditions",
    "inputs_schema",
    "outputs_schema",
    "entities",
    "procedure",
    "provenance",
    "extensions"
  ],
  "properties": {
    "kind": {
      "const": "agent-procedure"
    },
    "spec_version": {
      "const": "0.1.0"
    },
    "procedure_id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "entry_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs_schema": {
      "$ref": "#/$defs/jsonSchemaObject"
    },
    "outputs_schema": {
      "$ref": "#/$defs/jsonSchemaObject"
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "procedure": {
      "$ref": "#/$defs/procedure"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "jsonSchemaObject": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonSchemaProperty"
          }
        },
        "additionalProperties": {
          "type": [
            "boolean",
            "object"
          ]
        }
      }
    },
    "jsonSchemaProperty": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "x-source_hint": {
          "type": "string"
        }
      }
    },
    "procedure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_node",
        "nodes",
        "transitions"
      ],
      "properties": {
        "start_node": {
          "type": "string",
          "minLength": 1
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transition"
          }
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "name",
        "observed_vs_inferred"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "action",
            "decision",
            "approval",
            "terminal"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "instruction": {
          "type": "string"
        },
        "question": {
          "type": "string"
        },
        "evaluation_hint": {
          "type": "string"
        },
        "approval_required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "outcome": {
          "enum": [
            "success",
            "failure",
            "canceled"
          ]
        },
        "uses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "produces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "context_hints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contextHint"
          }
        },
        "pre_state_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "completion_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recovery": {
          "$ref": "#/$defs/recovery"
        },
        "risk": {
          "$ref": "#/$defs/risk"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "observed_vs_inferred": {
          "enum": [
            "observed",
            "inferred",
            "authored"
          ]
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "action"
              }
            }
          },
          "then": {
            "required": [
              "instruction"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "decision"
              }
            }
          },
          "then": {
            "required": [
              "question"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "approval"
              }
            }
          },
          "then": {
            "required": [
              "approval_required",
              "reason"
            ],
            "properties": {
              "approval_required": {
                "const": true
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "terminal"
              }
            }
          },
          "then": {
            "required": [
              "outcome"
            ]
          }
        }
      ]
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "default",
        "observed_vs_inferred"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        },
        "default": {
          "type": "boolean"
        },
        "observed_vs_inferred": {
          "enum": [
            "observed",
            "inferred",
            "authored"
          ]
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "name",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "source_hint": {
          "type": "string"
        },
        "observed_value": {
          "type": "string"
        }
      }
    },
    "contextHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "instructions"
      ],
      "properties": {
        "strategy": {
          "enum": [
            "retry",
            "ask-user",
            "skip",
            "abort",
            "fallback"
          ]
        },
        "instructions": {
          "type": "string"
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "irreversible",
        "confirmation_required",
        "reason"
      ],
      "properties": {
        "level": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "irreversible": {
          "type": "boolean"
        },
        "confirmation_required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "reference"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer",
        "source_type",
        "created_at",
        "confidence",
        "observed_vs_inferred_summary"
      ],
      "properties": {
        "producer": {
          "type": "string"
        },
        "source_type": {
          "enum": [
            "observed",
            "authored",
            "converted",
            "generated"
          ]
        },
        "source_session_id": {
          "type": "string",
          "description": "Required when source_type is 'observed'."
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "capture_scope": {
          "$ref": "#/$defs/captureScope",
          "description": "Expected when source_type is 'observed'."
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "observed_vs_inferred_summary": {
          "type": "string"
        }
      }
    },
    "captureScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applications",
        "key_files"
      ],
      "properties": {
        "applications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "key_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall",
        "per_node"
      ],
      "properties": {
        "overall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "per_node": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nodeConfidence"
          }
        }
      }
    },
    "nodeConfidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "confidence"
      ],
      "properties": {
        "node_id": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
